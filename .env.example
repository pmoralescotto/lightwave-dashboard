# Copy this file to .env and fill in your values

# Monday.com OAuth App Client ID (public - safe for frontend)
VITE_MONDAY_CLIENT_ID=your_client_id_here

# Monday.com OAuth App Client Secret (KEEP SECRET - used only by Netlify function)
MONDAY_CLIENT_SECRET=your_client_secret_here

# OAuth redirect URI - must match Monday.com app settings exactly
VITE_REDIRECT_URI=http://localhost:5173/oauth/callback

# For production:
# VITE_REDIRECT_URI=https://your-site.netlify.app/oauth/callback
